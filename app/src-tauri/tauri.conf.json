{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MerkWerk",
  "version": "0.0.0",
  "identifier": "com.merkwerk.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MerkWerk",
        "width": 1000,
        "height": 700,
        "minWidth": 640,
        "minHeight": 480
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
